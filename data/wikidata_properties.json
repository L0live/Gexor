  "A_redundancy_groups": {
    "_description": "Ces groupes contiennent des propriétés wikibase-item dont l'information est HIÉRARCHIQUEMENT DÉRIVABLE d'une autre. Règle générale : garder uniquement la propriété la plus spécifique comme arête primaire du graphe ; mettre les autres en secondaire.",

    "A1_localisation_geographique_territoire": {
      "_label": "Localisation géographique, lieux biographiques et juridiction — hiérarchie emboîtée",
      "_rationale": "Ces propriétés décrivent la localisation d'une entité sous plusieurs angles redondants. (1) Hiérarchie géographique stricte : continent > pays > division adm. 1 > localité > adresse — tout niveau supérieur est dérivable via P131*/P17/P30. (2) Lieux biographiques : P19/P20 (naissance/mort) sont les arêtes primaires ; le pays/continent associé est dérivable par traversée. (3) Juridiction : P1001 est doublon fonctionnel de P17/P131 dans la plupart des contextes.",
      "_hierarchy": "P625 (coordonnées) → P670/P6375 (adresse) → P131 (entité admin.) → P17 (pays) → P30 (continent)",
      "_keep_as_primary": "P131 (localisation la plus spécifique), P19, P20 (lieux biographiques eux-mêmes)",
      "properties": {
        "P17":   { "label": "pays", "datatype": "wikibase-item", "note": "Dérivable de P131* via entité administrative → pays" },
        "P30":   { "label": "continent", "datatype": "wikibase-item", "note": "Dérivable de P17 → P30" },
        "P276":  { "label": "lieu (location générique)", "datatype": "wikibase-item", "note": "Souvent redondant avec P131" },
        "P1376": { "label": "capitale de", "datatype": "wikibase-item", "note": "Relation inverse de P36, redondant en contexte" },
        "P3842": { "label": "situé dans l'entité administrative actuelle", "datatype": "wikibase-item", "note": "Doublon historique de P131" },
        "P6885": { "label": "région historique", "datatype": "wikibase-item", "note": "Complément contextuel, rarement primaire" },
        "P706":  { "label": "situé dans le terrain (relief)", "datatype": "wikibase-item", "note": "Détail géographique physique" },
        "P206":  { "label": "situé dans ou à côté d'un plan d'eau", "datatype": "wikibase-item", "note": "Détail géographique, secondaire" },
        "P669":  { "label": "situé sur la rue", "datatype": "wikibase-item", "note": "Niveau adresse — très spécifique, secondaire" },
        "P708":  { "label": "diocèse", "datatype": "wikibase-item", "note": "Division ecclésiastique — rarement pertinente en graphe généraliste" },
        "P5607": { "label": "entité territoriale religieuse", "datatype": "wikibase-item", "note": "Idem" },
        "P27":   { "label": "pays de nationalité / citoyenneté", "datatype": "wikibase-item", "note": "Souvent dérivable de P19→P17 ou P551→P17. Pertinent uniquement si différent du lieu de naissance (ex: exil, naturalisation).", "context_dependent": true },
        "P551":  { "label": "lieu de résidence", "datatype": "wikibase-item", "note": "Doublon fréquent de P19 ou P937 (lieu de travail)" },
        "P937":  { "label": "lieu de travail", "datatype": "wikibase-item", "note": "Souvent redondant avec l'institution (P108)" },
        "P1411": { "label": "nommé pour (prix)", "datatype": "wikibase-item", "note": "Redondant avec P166 (award received)" },
        "P119":  { "label": "lieu de sépulture", "datatype": "wikibase-item", "note": "Détail biographique terminal, rarement exploitable comme arête de graphe" },
        "P1001": { "label": "applies to jurisdiction", "datatype": "wikibase-item", "note": "Doublon fonctionnel de P17 dans beaucoup de contextes" },
        "P194":  { "label": "assemblée législative", "datatype": "wikibase-item", "note": "Relation gouvernance souvent dérivable" },
        "P1906": { "label": "office held by head of government", "datatype": "wikibase-item", "note": "Doublon de P6 (head of government) sous forme inverse" },
        "P1308": { "label": "officeholder", "datatype": "wikibase-item", "note": "Inverse de P39, redondant" }
      }
    },

